{
  "private": true,
  "name": "wholesome-shield",
  "version": "0.0.0",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "npm run type-check && vite build",
    "deploy": "npm run type-check && npm run lint && npm run test && devvit upload",
    "dev": "devvit playtest",
    "launch": "npm run deploy && devvit publish",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "login": "devvit login",
    "prettier": "prettier --write .",
    "test": "vitest run",
    "type-check": "tsc --build"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/redis": "^0.12.24",
    "@devvit/settings": "^0.12.24",
    "@devvit/start": "^0.12.24",
    "@devvit/web": "^0.12.24",
    "@hono/node-server": "^1.19.9",
    "devvit": "^0.12.24",
    "hono": "4.12.19"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "^22.19.7",
    "eslint": "9.39.2",
    "globals": "17.2.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vite": "7.3.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "protobufjs": "7.5.9"
  }
}
